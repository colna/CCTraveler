[agent]
model = "claude-sonnet-4-20250514"
max_turns = 50
api_key = ""       # Anthropic API key, or set ANTHROPIC_API_KEY env var
base_url = ""      # Leave empty for official API, or set your proxy URL

[scraper]
base_url = "http://localhost:8300"
timeout_secs = 120
max_retries = 3

[storage]
db_path = "data/cctraveler.db"

[ctrip]
default_city = "558"
default_adults = 1
default_children = 0
request_delay_ms = 3000
max_concurrent = 3
proxy_pool = []
